#####################################################################
# TEMPLATE — NOT a working configuration
#
# Copy to .env and replace EVERY placeholder before starting services.
# Generate strong secrets with:
#   openssl rand -hex 32        # 64-char hex string
#   openssl rand -base64 24     # 32-char base64 string
#
# NEVER commit .env or use these defaults on staging / production.
#####################################################################

# DB
DATABASE_URL=postgres://oecophylla:CHANGE_ME__use_openssl_rand_base64_24@postgres:5432/oecophylla
POSTGRES_DB=oecophylla
POSTGRES_USER=oecophylla
POSTGRES_PASSWORD=CHANGE_ME__use_openssl_rand_base64_24

# Redis
REDIS_URL=redis://:CHANGE_ME__use_openssl_rand_base64_24@redis:6379
REDIS_PASSWORD=CHANGE_ME__use_openssl_rand_base64_24

# Kafka (KRaft single-node)
KAFKA_BROKERS=kafka:9092
KAFKA_CLUSTER_ID=MkU3OEVBNTcwNTJENDM2Qw

# Auth
JWT_SECRET=CHANGE_ME__min_32_chars__use_openssl_rand_hex_32
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=604800
ARGON2_M_COST=19456
ARGON2_T_COST=2
ARGON2_P_COST=1

# Service internal URLs
AUTH_SERVICE_URL=http://auth-service:8001
USER_SERVICE_URL=http://user-service:8002
CONTENT_SERVICE_URL=http://content-service:8003
ENVOY_URL=http://envoy:8080

# Frontend
PUBLIC_API_BASE=/api/v1
ORIGIN=http://localhost:3000

# Rate limits
RATE_LIMIT_PUBLIC=60
RATE_LIMIT_AUTHED=200

# Grafana
GF_SECURITY_ADMIN_PASSWORD=CHANGE_ME__strong_password
